# --- Auth: choose AI Studio OR Vertex AI (Agent Builder) ---

# Option A — Google AI Studio (local dev, no GCP project needed)
GEMINI_API_KEY=your_gemini_api_key_here

# Option B — Google Cloud Agent Builder (Vertex AI)
# Run: gcloud auth application-default login
# Then set these and use --vertex flag (or pipelineguard deploy)
GCP_PROJECT=your_gcp_project_id
GCP_LOCATION=us-central1

# GitLab Personal Access Token — needs api + read_repository scopes.
# PipelineGuard's MCP backend also re-exports this as GITLAB_PERSONAL_ACCESS_TOKEN
# to the bundled mcp_server subprocess, so you only need to set it here.
# (Set GITLAB_PERSONAL_ACCESS_TOKEN directly if running `pipelineguard-mcp` standalone,
#  e.g. from Claude Desktop or another MCP-compatible client.)
GITLAB_TOKEN=your_gitlab_pat_here

# GitLab base URL (default: https://gitlab.com, change for self-hosted)
GITLAB_URL=https://gitlab.com

# --- Splunk (for: pipelineguard splunk investigate) ---
# Encrypted token from Splunk MCP Server App UI (Splunkbase App ID 7931)
SPLUNK_MCP_TOKEN=your_splunk_mcp_token_here

# MCP endpoint: primary (port 8089) or fallback (port 443)
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
