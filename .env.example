# Google Gemini API key — get one at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# GitLab Personal Access Token — needs api + read_repository scopes
GITLAB_TOKEN=your_gitlab_pat_here

# GitLab base URL (default: https://gitlab.com, change for self-hosted)
GITLAB_URL=https://gitlab.com
