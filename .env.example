# Google Gemini API key — get one at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# GitLab Personal Access Token — needs api + read_repository scopes
GITLAB_TOKEN=your_gitlab_pat_here

# GitLab base URL (default: https://gitlab.com, change for self-hosted)
GITLAB_URL=https://gitlab.com

# --- Splunk (for: pipelineguard splunk investigate) ---
# Encrypted token from Splunk MCP Server App UI (Splunkbase App ID 7931)
SPLUNK_MCP_TOKEN=your_splunk_mcp_token_here

# MCP endpoint: primary (port 8089) or fallback (port 443)
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
